# Storage backend selection.
# "json"     -> use the existing data/clients.json file (default; safe).
# "postgres" -> use PostgreSQL. Requires DATABASE_URL to also be set.
# Merely setting DATABASE_URL does NOT switch this on by itself.
STORAGE_BACKEND=json

# Used only when STORAGE_BACKEND=postgres. Railway injects this
# automatically once a Postgres plugin is attached to the project, but
# attaching the plugin alone does not change which backend is active.
DATABASE_URL=postgresql://user:password@localhost:5432/vianova_dev

# JSON storage location (used when STORAGE_BACKEND=json, i.e. by default).
DATA_DIR=./data

# Shared access-code gate (frontend AccessGate.jsx / /api/auth.js) and the
# header the Vercel proxy functions attach to backend requests.
ACCESS_CODE=replace-with-a-real-access-code
TRIAL_API_KEY=replace-with-a-real-trial-key

# Anthropic / Tavily — required for AI features (CV Studio, Positioning,
# Market Radar, Advisor Brief, Target Contacts search).
ANTHROPIC_API_KEY=sk-ant-replace-me
TAVILY_API_KEY=tvly-replace-me

# Optional per-feature model overrides (defaults shown are the current
# in-code fallbacks; uncomment only to override).
# CV_INTELLIGENCE_MODEL=claude-sonnet-4-6
# POSITIONING_MODEL=claude-haiku-4-5-20251001
# ADVISOR_BRIEF_MODEL=claude-sonnet-4-6
# MARKET_RADAR_MODEL=claude-haiku-4-5-20251001
# LLM_JUDGMENT_MODEL=claude-haiku-4-5-20251001
# LLM_JUDGMENT_MAX_ADJUSTMENT=10
